<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/countdown_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/countdown_widget_background"
    android:gravity="center_vertical"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/countdown_kicker"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/widget_kicker_bg"
        android:paddingLeft="8dp"
        android:paddingTop="4dp"
        android:paddingRight="8dp"
        android:paddingBottom="4dp"
        android:text="CUENTA ATRAS"
        android:textColor="#F8FAFC"
        android:textSize="10sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/countdown_value"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="3d"
        android:textColor="#FFFFFF"
        android:textSize="38sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/countdown_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="Para empezar"
        android:textColor="#D6E2FF"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/countdown_plan_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:ellipsize="end"
        android:maxLines="2"
        android:text="Concierto Antoinne"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/countdown_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="24 abr · paris"
        android:textColor="#C9D6F2"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/countdown_date"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="vie 24 abr · 10:00"
        android:textColor="#8FB5FF"
        android:textSize="12sp"
        android:textStyle="bold" />

</LinearLayout>
